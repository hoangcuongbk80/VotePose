# Build an docker image
nvidia-docker build --tag votegrasp ./

# create a container
nvidia-docker run --name my_votepose -it --rm -v /home/cghg/VotePose/:/VotePose -v /media/DiskStation/trsv/data/ycbpose:/ycbpose_dataset --ipc=host votegrasp /bin/bash

# training
cd pointnet2
python setup.py install
python train.py --dataset ycbgrasp --log_dir log_ycbpose

# testing
python predict.py
